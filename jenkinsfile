pipeline {
    agent { label 'Jenkins-Agent' }

    tools {
        jdk 'Java17'  // Ensure Java 17 is configured in Jenkins Global Tool Configuration
        maven 'Maven3' // Ensure Maven 3 is configured in Jenkins Global Tool Configuration
    }

    environment {
        SONARQUBE_TOKEN = 'sqa_c91633d5ba48c4131f20e517dbda47633cc08a63' // SonarQube Token (ensure this is set securely)
    }

    stages {
        stage("Cleanup Workspace") {
            steps {
                cleanWs() // Clean workspace before starting the build
            }
        }

        stage("Checkout from SCM") {
            steps {
                git branch: 'master', credentialsId: 'github', url: 'https://github.com/AbuAbbasNaqvi/profilesapp.git'
            }
        }

        stage("Build Application") {
            steps {
                script {
                    def projectDir = 'profilesapp' // Directory where the project is located
                    if (fileExists("${projectDir}/pom.xml")) {
                        dir("${projectDir}") {
                            // Use Maven to build the application
                            sh "mvn clean package -DskipTests" // Skip tests for faster builds (can be removed if needed)
                        }
                    } else {
                        error "pom.xml not found in directory: ${projectDir}"
                    }
                }
            }
        }

        stage("Test Application") {
            steps {
                script {
                    def projectDir = 'profilesapp' // Directory where the project is located
                    if (fileExists("${projectDir}/pom.xml")) {
                        dir("${projectDir}") {
                            // Run tests using Maven
                            sh "mvn test"
                        }
                    } else {
                        error "pom.xml not found in directory: ${projectDir}"
                    }
                }
            }
        }

        stage("SonarQube Analysis") {
            steps {
                script {
                    def projectDir = 'profilesapp' // Directory where the project is located
                    if (fileExists("${projectDir}/pom.xml")) {
                        dir("${projectDir}") {
                            // Run SonarQube analysis
                            withSonarQubeEnv('sonarqube-server') {  // Make sure SonarQube is configured correctly in Jenkins
                                sh "mvn clean verify sonar:sonar -Dsonar.projectKey=profilesapp -Dsonar.host.url=http://your-sonarqube-server-url -Dsonar.login=${SONARQUBE_TOKEN}"
                            }
                        }
                    } else {
                        error "pom.xml not found in directory: ${projectDir}"
                    }
                }
            }
        }
    }
}
