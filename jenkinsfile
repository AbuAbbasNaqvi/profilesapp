pipeline {
    agent { label 'Jenkins-Agent' }

    tools {
        jdk 'Java17'
        maven 'Maven3'
    }

    environment {
        SONARQUBE_TOKEN = 'sqa_c91633d5ba48c4131f20e517dbda47633cc08a63' // Token value
    }

    stages {
        stage("Cleanup Workspace") {
            steps {
                cleanWs()
            }
        }

        stage("Checkout from SCM") {
            steps {
                git branch: 'master', credentialsId: 'github', url: 'https://github.com/AbuAbbasNaqvi/profilesapp.git'
            }
        }

        stage("Build Application") {
            steps {
                script {
                    def projectDir = 'profilesapp' // Change this to the correct directory if needed
                    if (fileExists("${projectDir}/pom.xml")) {
                        dir("${projectDir}") {
                            sh "mvn clean package -DskipTests" // Optional: Skips tests for faster builds
                        }
                    } else {
                        error "pom.xml not found in directory: ${projectDir}"
                    }
                }
            }
        }

        stage("Test Application") {
            steps {
                script {
                    def projectDir = 'profilesapp' // Change this to the correct directory if needed
                    if (fileExists("${projectDir}/pom.xml")) {
                        dir("${projectDir}") {
                            sh "mvn test"
                        }
                    } else {
                        error "pom.xml not found in directory: ${projectDir}"
                    }
                }
            }
        }

        stage("SonarQube Analysis") {
            steps {
                script {
                    def projectDir = 'profilesapp' // Change this to the correct directory if needed
                    if (fileExists("${projectDir}/pom.xml")) {
                        dir("${projectDir}") {
                            // Run SonarQube scanner analysis
                            withSonarQubeEnv('sonarqube-server') {  // Use the name of the SonarQube server configured in Jenkins
                                sh "mvn clean verify sonar:sonar -Dsonar.projectKey=profilesapp -Dsonar.host.url=http://your-sonarqube-server-url -Dsonar.login=${SONARQUBE_TOKEN}"
                            }
                        }
                    } else {
                        error "pom.xml not found in directory: ${projectDir}"
                    }
                }
            }
        }

        stage("Archive Artifacts") {
            steps {
                archiveArtifacts '**/target/*.jar'
            }
        }
    }
}
